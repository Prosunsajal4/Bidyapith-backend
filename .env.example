# Backend (Express)
# Copy this file to .env

PORT=3000

# Option A (recommended): full MongoDB connection string
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Option B: separate credentials (used only if MONGODB_URI is empty)
DB_USER=
DB_PASS=

# Firebase Admin service account key JSON (DO NOT COMMIT)
# Example: C:\\path\\to\\firebase-admin-key.json
FIREBASE_KEY_PATH=

# Serverless-friendly alternative (recommended for Vercel):
# Paste the full service account JSON (single line), OR base64(JSON).
# Tip: you can minify JSON; base64 is often easiest for platforms with strict env parsing.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Stripe Payment Keys (get from https://dashboard.stripe.com/apikeys)
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Alias (supported):
FB_SERVICE_KEY=

# Optional
NODE_ENV=development
