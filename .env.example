# Example frontend env (do NOT store secrets here) - copy and fill locally
# For Next.js use NEXT_PUBLIC_... prefix; for CRA use REACT_APP_...
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Backend: (FB_SERVICE_KEY should be base64-encoded service account JSON)
# FB_SERVICE_KEY=BASE64_ENCODED_JSON
